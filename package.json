{
    "name": "github-contribution-minesweeper",
    "version": "1.0.0",
    "description": "🎮💣 Generates a minesweeper game animation from your GitHub contribution graph",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "package": "ncc build src/action.ts -o dist --license licenses.txt",
        "dev": "ts-node src/index.ts",
        "test": "jest",
        "generate": "ts-node src/cli.ts",
        "lint": "eslint src/**/*.ts",
        "prepublishOnly": "npm run build && npm run package"
    },
    "keywords": [
        "github",
        "contribution",
        "minesweeper",
        "svg",
        "animation",
        "profile",
        "readme",
        "github-action"
    ],
    "author": "Jair Chavez Islas",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Jair0305/github-contribution-minesweeper"
    },
    "bugs": {
        "url": "https://github.com/Jair0305/github-contribution-minesweeper/issues"
    },
    "homepage": "https://github.com/Jair0305/github-contribution-minesweeper#readme",
    "dependencies": {
        "@actions/core": "^1.10.1",
        "@actions/github": "^6.0.0",
        "@octokit/graphql": "^7.0.2",
        "commander": "^12.0.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^20.11.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "@vercel/ncc": "^0.38.4",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}